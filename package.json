{
  "name": "stackray",
  "version": "0.2.0",
  "description": "Open-source technology detection and web scan platform.",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarlosCommits/stackray.git"
  },
  "homepage": "https://github.com/CarlosCommits/stackray#readme",
  "bugs": {
    "url": "https://github.com/CarlosCommits/stackray/issues"
  },
  "keywords": [
    "technology-detection",
    "website-scanner",
    "security",
    "wappalyzer",
    "nuclei",
    "httpx"
  ],
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:init": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/setup-dev-env.ts && pnpm dev:infra && pnpm db:migrate:startup && pnpm seed:admin --email admin@stackray.local --password StackrayDev123!",
    "dev:local": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/dev-local.ts",
    "dev:local:down": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/dev-local-compose.ts down",
    "dev:local:wipe": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/dev-local-compose.ts wipe",
    "dev:infra": "docker compose -f docker-compose.dev.yml up --wait --wait-timeout 120 postgres minio && docker compose -f docker-compose.dev.yml up --force-recreate minio-init",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:infra:logs": "docker compose -f docker-compose.dev.yml logs -f postgres minio worker-init worker-http worker-intel worker-browser",
    "dev:infra:reset": "docker compose -f docker-compose.dev.yml down -v",
    "build": "next build && node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/copy-next-standalone-assets.ts",
    "start": "pnpm db:migrate:startup && pnpm start:server",
    "start:server": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "lint": "eslint .",
    "knip": "knip --no-exit-code",
    "knip:prod": "knip --production --no-exit-code",
    "knip:strict": "knip",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "vitest run",
    "test:performance-contracts": "vitest run performance-contracts",
    "test:e2e": "playwright test",
    "test:railway-template": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/validate-railway-template.ts",
    "test:scan-pipeline-smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/scan-pipeline-smoke.ts",
    "test:watch": "vitest",
    "worker": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types worker/index.ts",
    "worker:docker": "docker compose -f docker-compose.dev.yml --profile worker up --build worker-http worker-intel worker-browser",
    "worker:docker:down": "docker compose -f docker-compose.dev.yml stop worker-http worker-intel worker-browser",
    "worker:once": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types worker/index.ts --once",
    "scanners:update": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/update-scanner-pins.ts",
    "seed:admin": "node --experimental-strip-types scripts/bootstrap-admin.ts",
    "wappalyzer:update-catalog": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/update-wappalyzer-catalog.ts",
    "wappalyzer:diff-catalog": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/wappalyzer-catalog-diff.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:startup": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/startup-migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1094.0",
    "@aws-sdk/s3-request-presigner": "^3.1094.0",
    "@base-ui/react": "^1.6.0",
    "@better-auth/drizzle-adapter": "^1.6.25",
    "better-auth": "^1.6.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "graphile-worker": "^0.17.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.26.0",
    "motion": "^12.42.2",
    "next": "16.2.11",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.5",
    "react": "19.2.8",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.8",
    "react-resizable-panels": "^4.12.2",
    "resend": "^6.18.0",
    "shadcn": "^4.14.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tldts": "^7.4.9",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.5"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentation": "^3.0.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "knip": "^6.29.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5",
    "vite": "7.3.5",
    "vitest": "^4.1.10"
  }
}
