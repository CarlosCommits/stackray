{
  "buckets": {
    "29e12e21-5b8f-433c-b273-d98121ef391a": {
      "name": "stackray-screenshots"
    }
  },
  "services": {
    "1c6d4235-4ff1-4a74-8c63-f76f5b4b9e47": {
      "icon": null,
      "name": "web",
      "deploy": {
        "startCommand": "pnpm start",
        "healthcheckPath": null,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "source": {
        "repo": "https://github.com/CarlosCommits/stackray",
        "rootDirectory": null
      },
      "variables": {
        "DATABASE_URL": {
          "isOptional": false,
          "defaultValue": "postgresql://postgres:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres"
        },
        "AWS_ENDPOINT_URL": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ENDPOINT}}"
        },
        "AWS_ACCESS_KEY_ID": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ACCESS_KEY_ID}}"
        },
        "AWS_DEFAULT_REGION": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.REGION}}"
        },
        "AWS_S3_BUCKET_NAME": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.BUCKET}}"
        },
        "BETTER_AUTH_SECRET": {
          "isOptional": false,
          "description": "Secret used to sign Better Auth sessions.",
          "defaultValue": "${{secret()}}"
        },
        "AWS_SECRET_ACCESS_KEY": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.SECRET_ACCESS_KEY}}"
        },
        "STACKRAY_ALLOWED_HOSTS": {
          "isOptional": true,
          "description": "Optional comma-separated custom hostnames that Stackray should trust in addition to Railway-provided domains.",
          "defaultValue": ""
        }
      },
      "networking": {
        "serviceDomains": {
          "<hasDomain>": {}
        }
      }
    },
    "71319e83-14d9-4f97-9411-2d34e5cacad1": {
      "icon": null,
      "name": "worker-http",
      "deploy": {
        "startCommand": "pnpm worker",
        "healthcheckPath": null,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "build": {
        "dockerfilePath": "worker/Dockerfile"
      },
      "source": {
        "repo": "https://github.com/CarlosCommits/stackray",
        "rootDirectory": null
      },
      "variables": {
        "STACKRAY_WORKER_ROLE": {
          "isOptional": false,
          "defaultValue": "http"
        },
        "DATABASE_URL": {
          "isOptional": false,
          "defaultValue": "postgresql://postgres:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres"
        },
        "AWS_ENDPOINT_URL": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ENDPOINT}}"
        },
        "AWS_ACCESS_KEY_ID": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ACCESS_KEY_ID}}"
        },
        "AWS_DEFAULT_REGION": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.REGION}}"
        },
        "AWS_S3_BUCKET_NAME": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.BUCKET}}"
        },
        "AWS_SECRET_ACCESS_KEY": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.SECRET_ACCESS_KEY}}"
        }
      }
    },
    "2d82cc68-b730-42bb-af10-aab97c4bd0e3": {
      "icon": null,
      "name": "worker-intel",
      "deploy": {
        "startCommand": "pnpm worker",
        "healthcheckPath": null,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "build": {
        "dockerfilePath": "worker/Dockerfile"
      },
      "source": {
        "repo": "https://github.com/CarlosCommits/stackray",
        "rootDirectory": null
      },
      "variables": {
        "STACKRAY_WORKER_ROLE": {
          "isOptional": false,
          "defaultValue": "intel"
        },
        "DATABASE_URL": {
          "isOptional": false,
          "defaultValue": "postgresql://postgres:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres"
        },
        "AWS_ENDPOINT_URL": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ENDPOINT}}"
        },
        "AWS_ACCESS_KEY_ID": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ACCESS_KEY_ID}}"
        },
        "AWS_DEFAULT_REGION": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.REGION}}"
        },
        "AWS_S3_BUCKET_NAME": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.BUCKET}}"
        },
        "AWS_SECRET_ACCESS_KEY": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.SECRET_ACCESS_KEY}}"
        }
      }
    },
    "f0bc8b45-485a-422e-af93-3812806a38ca": {
      "icon": null,
      "name": "worker-headless",
      "deploy": {
        "startCommand": "pnpm worker",
        "healthcheckPath": null,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "build": {
        "dockerfilePath": "worker/Dockerfile"
      },
      "source": {
        "repo": "https://github.com/CarlosCommits/stackray",
        "rootDirectory": null
      },
      "variables": {
        "STACKRAY_WORKER_ROLE": {
          "isOptional": false,
          "defaultValue": "headless"
        },
        "DATABASE_URL": {
          "isOptional": false,
          "defaultValue": "postgresql://postgres:${{Postgres.POSTGRES_PASSWORD}}@${{Postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/postgres"
        },
        "AWS_ENDPOINT_URL": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ENDPOINT}}"
        },
        "AWS_ACCESS_KEY_ID": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.ACCESS_KEY_ID}}"
        },
        "AWS_DEFAULT_REGION": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.REGION}}"
        },
        "AWS_S3_BUCKET_NAME": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.BUCKET}}"
        },
        "AWS_SECRET_ACCESS_KEY": {
          "isOptional": false,
          "defaultValue": "${{stackray-screenshots.SECRET_ACCESS_KEY}}"
        }
      }
    },
    "c4e4fadf-94a8-4b85-8445-ae4032ac3339": {
      "icon": "https://devicons.railway.app/i/postgresql.svg",
      "name": "Postgres",
      "deploy": {
        "startCommand": null,
        "healthcheckPath": null,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "source": {
        "image": "ghcr.io/railwayapp-templates/postgres-ssl:18"
      },
      "variables": {
        "PGDATA": {
          "isOptional": false,
          "defaultValue": "${{RAILWAY_VOLUME_MOUNT_PATH}}/pgdata"
        },
        "POSTGRES_PASSWORD": {
          "isOptional": false,
          "defaultValue": "${{ secret(32, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ\") }}"
        }
      },
      "networking": {
        "tcpProxies": {
          "5432": {}
        }
      },
      "volumeMounts": {
        "c4e4fadf-94a8-4b85-8445-ae4032ac3339": {
          "mountPath": "/var/lib/postgresql/data"
        }
      }
    }
  }
}
